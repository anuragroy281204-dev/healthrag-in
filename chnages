/* SECTIONS */
section {
  padding: 140px 48px;
  position: relative;
  z-index: 1;
}
@media (max-width: 768px) { section { padding: 80px 20px; } }
.container { max-width: 1200px; margin: 0 auto; }

.section-eyebrow {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--cyan);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.section-eyebrow::before {
  content: '';
  width: 24px;
  height: 1px;
  background: var(--cyan);
}
.section-title {
  font-family: var(--display);
  font-weight: 400;
  font-size: clamp(36px, 5.5vw, 72px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--cream);
  margin-bottom: 80px;
}
.section-title em {
  font-style: italic;
  background: linear-gradient(135deg, var(--cyan), var(--cyan-soft));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* PIPELINE */
.pipeline {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24px;
}
@media (max-width: 768px) { .pipeline { grid-template-columns: 1fr; } }
.pipe-step {
  background: linear-gradient(180deg, rgba(15, 31, 53, 0.5), rgba(20, 41, 68, 0.3));
  border: 1px solid var(--rule);
  border-radius: 20px;
  padding: 36px;
  transition: all 0.4s ease;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.pipe-step:hover {
  transform: translateY(-4px);
  border-color: var(--cyan);
  background: linear-gradient(180deg, rgba(15, 31, 53, 0.8), rgba(0, 217, 255, 0.05));
}
.pipe-num {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 500;
  color: var(--cyan);
  letter-spacing: 0.15em;
  margin-bottom: 32px;
}
.pipe-h {
  font-family: var(--display);
  font-weight: 500;
  font-size: 36px;
  letter-spacing: -0.03em;
  color: var(--cream);
  margin-bottom: 16px;
}
.pipe-p {
  font-size: 15px;
  color: var(--cream-2);
  line-height: 1.7;
  margin-bottom: 24px;
  font-weight: 300;
}
.pipe-tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.pipe-tag {
  display: inline-block;
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  color: var(--cyan-soft);
  padding: 6px 12px;
  border: 1px solid var(--rule);
  border-radius: 100px;
  background: rgba(0, 217, 255, 0.04);
}

/* SOURCES */
.sources-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
@media (max-width: 900px) { .sources-grid { grid-template-columns: 1fr; } }
.source-card {
  background: linear-gradient(180deg, rgba(15, 31, 53, 0.5), rgba(20, 41, 68, 0.3));
  border: 1px solid var(--rule);
  border-radius: 20px;
  padding: 36px;
  transition: all 0.4s ease;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.source-card:hover {
  transform: translateY(-4px);
  border-color: var(--cyan);
}
.source-card-feature {
  background: linear-gradient(180deg, rgba(0, 217, 255, 0.08), rgba(0, 217, 255, 0.02));
  border-color: rgba(0, 217, 255, 0.3);
}
.source-logo {
  width: 100%;
  height: 100px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.06), rgba(0, 217, 255, 0.02));
  border: 1px solid var(--rule);
  border-radius: 14px;
  margin-bottom: 24px;
}
.logo-placeholder {
  font-family: var(--display);
  font-weight: 700;
  font-size: 36px;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, var(--cyan), var(--cream));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.source-meta {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--rule);
  gap: 12px;
}
.source-name {
  font-family: var(--display);
  font-weight: 500;
  font-size: 18px;
  letter-spacing: -0.01em;
  color: var(--cream);
  line-height: 1.3;
  flex: 1;
}
.source-stat {
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  color: var(--cyan);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
}
.source-p {
  font-size: 14px;
  color: var(--cream-2);
  line-height: 1.7;
  font-weight: 300;
  margin-bottom: 20px;
}
.source-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
}
.src-tag {
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: var(--cream-2);
  padding: 5px 10px;
  background: rgba(0, 217, 255, 0.04);
  border: 1px solid var(--rule);
  border-radius: 100px;
}
.source-link {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 500;
  color: var(--cyan);
  letter-spacing: 0.05em;
  transition: opacity 0.2s;
}
.source-link:hover { opacity: 0.7; }

/* WHY */
.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
@media (max-width: 900px) { .why-grid { grid-template-columns: 1fr; } }
.why-card {
  background: rgba(15, 31, 53, 0.4);
  border: 1px solid var(--rule);
  border-radius: 20px;
  padding: 32px;
  transition: all 0.4s ease;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}
.why-card:hover {
  transform: translateY(-4px);
  border-color: var(--cyan);
  background: rgba(0, 217, 255, 0.04);
}
.why-icon {
  font-size: 32px;
  color: var(--cyan);
  margin-bottom: 24px;
  line-height: 1;
}
.why-h {
  font-family: var(--display);
  font-weight: 500;
  font-size: 22px;
  letter-spacing: -0.02em;
  color: var(--cream);
  margin-bottom: 12px;
}
.why-p {
  font-size: 14px;
  color: var(--cream-2);
  line-height: 1.7;
  font-weight: 300;
}

/* CTA */
.cta-section {
  padding: 160px 48px;
  text-align: center;
  background: radial-gradient(ellipse at center, rgba(0, 217, 255, 0.06) 0%, transparent 60%);
}
.cta-container { text-align: center; }
.cta-title {
  font-family: var(--display);
  font-weight: 400;
  font-size: clamp(48px, 8vw, 96px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: var(--cream);
  margin-bottom: 24px;
}
.cta-title em {
  font-style: italic;
  background: linear-gradient(135deg, var(--cyan), var(--cream));
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.cta-p {
  font-size: 18px;
  color: var(--cream-2);
  font-weight: 300;
  margin-bottom: 40px;
  max-width: 480px;
  margin: 0 auto 40px;
}
.cta-disclaimer {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--cream-3);
  margin-top: 32px;
  letter-spacing: 0.05em;
}

/* FOOTER */
.footer {
  padding: 60px 48px 40px;
  border-top: 1px solid var(--rule);
  position: relative;
  z-index: 1;
  background: rgba(10, 22, 40, 0.5);
}
.footer-container {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 24px;
  margin-bottom: 40px;
}
.footer-p {
  font-size: 13px;
  color: var(--cream-3);
  margin-top: 12px;
  max-width: 320px;
}
.footer-links {
  display: flex;
  gap: 24px;
  font-family: var(--mono);
  font-size: 13px;
}
.footer-links a {
  color: var(--cream-2);
  transition: color 0.2s;
}
.footer-links a:hover { color: var(--cyan); }
.footer-bottom {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--cream-3);
  text-align: center;
  padding-top: 24px;
  border-top: 1px solid var(--rule);
  letter-spacing: 0.05em;
}